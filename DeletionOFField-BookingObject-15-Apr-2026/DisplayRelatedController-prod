    @AuraEnabled
    public static String getAnnouncement(){
        String UserEmail = UserInfo.getUserEmail();
        String DueAmount = '';
        Decimal AmtDemanded = 0;
        //User u = [Select id,Name From User where Email=: UserEmail];
		Account acc = [Select id, name from Account where PersonEmail =:UserEmail and Customer_Portal_User__c = true ];
        system.debug('acc::'+acc);
        List<Booking__c> bklist = [Select id,name,TotalAmountDemanded__c,TotalAmountPaid__c,TotalAmountBalance__c from Booking__c where Account__c=:acc.id];
        system.debug('bklist::'+bklist);
        for(Booking__c b :bklist){
            AmtDemanded += b.TotalAmountBalance__c;
        }
        
        if(AmtDemanded > 0){
            //DueAmount = 'Total Amount Demanded : '+InventoryCostServices.INFormatR(AmtDemanded)+'***** Balance Amount : '+bklist[0].TotalAmountBalance__c+'';
            DueAmount = 'Due Amount : '+InventoryCostServices.INFormatR(AmtDemanded)+'';
        }else{
            DueAmount = '';
        }
        system.debug('DueAmount::'+DueAmount);
        return DueAmount;
    }
