            }
            .termAndCond{
            text-align:left !important;
            padding:5px;
            font-size: 11px;
            
            }
            @page{
            .rotate{
            /* Safari */
            -webkit-transform: rotate(-90deg);
            
            /* Firefox */
            -moz-transform: rotate(-90deg);
            
            /* IE */
            -ms-transform: rotate(-90deg);
            
